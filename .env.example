# Agentbook persistence. SQLite remains the safe default.
PERSISTENCE_BACKEND=sqlite

# Required only when PERSISTENCE_BACKEND=cockroach. Never commit a real value.
DATABASE_URL=
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_CONNECT_TIMEOUT=15
DATABASE_MAX_TRANSACTION_RETRIES=5
DATABASE_RETRY_BASE_DELAY_MS=100

EMBEDDING_DIMENSION=384
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
ENABLE_VECTOR_INDEX=true

# Public Guest Workspace mode. Generate a private value of at least 32 bytes;
# never commit the real value. Set the legacy switch only for explicit local
# compatibility tests, never for a public demo.
GUEST_SESSION_TOKEN_PEPPER=
GUEST_SESSION_TTL_DAYS=
GUEST_SESSION_LAST_SEEN_MINUTES=5
GUEST_SESSION_CREATION_LIMIT_PER_MINUTE=30
ALLOW_LEGACY_DEFAULT_WORKSPACE=false
FRONTEND_ORIGIN=http://127.0.0.1:5173

# Configure one supported LLM provider locally. Never put a real key here.
LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_MODEL=
